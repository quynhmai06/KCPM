  },
  "item": [
    {
      "name": "Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const rawTc = pm.iterationData.get(\"tc\");\r",
              "const tc = String(rawTc || \"\").trim();\r",
              "const desc = pm.iterationData.get(\"description\") || \"\";\r",
              "\r",
              "const expectedByTc = {\r",
              "  REG_TC01: { status: 201 },\r",
              "  REG_TC02: { status: 201 },\r",
              "  REG_TC03: { status: 201 },\r",
              "  REG_TC04: { status: 201 },\r",
              "  REG_TC05: { status: 201 },\r",
              "\r",
              "  REG_TC06: { status: 400, error: \"missing_fields\" },\r",
              "  REG_TC07: { status: 400 },\r",
              "\r",
              "  REG_TC08: { status: 409, error: \"username_exists\" },\r",
              "\r",
              "  REG_TC09: { status: 201 },\r",
              "  REG_TC10: { status: 201 },\r",
              "\r",
              "  REG_TC11: { status: 400, error: \"missing_fields\" },\r",
              "  REG_TC12: { status: 400 },\r",
              "\r",
              "  REG_TC13: { status: 409, error: \"email_exists\" },\r",
              "\r",
              "  REG_TC14: { status: 201 },\r",
              "  REG_TC15: { status: 400 },\r",
              "  REG_TC16: { status: 201 },\r",
              "  REG_TC17: { status: 400 },\r",
              "  REG_TC18: { status: 201 },\r",
              "  REG_TC19: { status: 201 },\r",
              "  REG_TC20: { status: 201 },\r",
              "  REG_TC21: { status: 400 },\r",
              "  REG_TC22: { status: 400 },\r",
              "\r",
              "  REG_TC23: { status: 409, error: \"phone_exists\" },\r",
              "\r",
              "  REG_TC24: { status: 201 },\r",
              "  REG_TC25: { status: 201 },\r",
              "  REG_TC26: { status: 201 },\r",
              "  REG_TC27: { status: 201 }\r",
              "};\r",
              "\r",
              "const expected = expectedByTc[tc];\r",
              "\r",
              "pm.test(`${tc} - ${desc} - đúng HTTP status`, function () {\r",
              "  pm.expect(expected, `Chưa khai báo expected cho ${tc}`).to.exist;\r",
              "  pm.response.to.have.status(expected.status);\r",
              "});\r",
              "\r",
              "let json = {};\r",
              "try {\r",
              "  json = pm.response.json();\r",
              "} catch (e) {}\r",
              "\r",
              "if (expected && expected.error) {\r",
              "  pm.test(`${tc} - đúng mã lỗi ${expected.error}`, function () {\r",
              "    pm.expect(json.error).to.eql(expected.error);\r",
              "  });\r",
              "}\r",
              "\r",
              "if (expected && expected.status === 201) {\r",
              "  pm.test(`${tc} - đăng ký thành công`, function () {\r",
              "    pm.expect(json).to.have.property(\"id\");\r",
              "    pm.expect(json.username).to.eql(pm.iterationData.get(\"username\"));\r",
              "  });\r",
              "}\r",
              "\r",
              "console.log(\r",
              "  \"tc:\", tc,\r",
              "  \"desc:\", desc,\r",
              "  \"expected:\", expected,\r",
              "  \"actual:\", pm.response.code,\r",
              "  \"body:\", pm.response.text()\r",
              ");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"{{username}}\",\r\n  \"email\": \"{{email}}\",\r\n  \"password\": \"{{password}}\",\r\n  \"phone\": \"{{phone}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{auth_url}}/auth/register",
          "host": [
            "{{auth_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Profile",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const row = pm.iterationData.toObject();\r",
              "const has = (key) => Object.prototype.hasOwnProperty.call(row, key);\r",
              "const pick = (key, fallback) => has(key) ? row[key] : fallback;\r",
              "\r",
              "function text(ch, len) {\r",
              "  return ch.repeat(Number(len));\r",
              "}\r",
              "\r",
              "const authType = pick(\"authorization_type\", \"member\");\r",
              "\r",
              "if (authType === \"none\") {\r",
              "  pm.variables.set(\"authorization\", \"\");\r",
              "} else if (authType === \"invalid\") {\r",
              "  pm.variables.set(\"authorization\", \"Bearer invalid-token\");\r",
              "} else {\r",
              "  pm.variables.set(\"authorization\", \"Bearer \" + pm.environment.get(\"memberToken\"));\r",
              "}\r",
              "\r",
              "const fullName = has(\"full_name_length\")\r",
              "  ? text(\"n\", row.full_name_length)\r",
              "  : pick(\"full_name\", text(\"n\", 60));\r",
              "\r",
              "const address = has(\"address_length\")\r",
              "  ? text(\"a\", row.address_length)\r",
              "  : pick(\"address\", text(\"a\", 128));\r",
              "\r",
              "pm.variables.set(\"full_name\", fullName);\r",
              "pm.variables.set(\"phone\", pick(\"phone\", \"0901234567\"));\r",
              "pm.variables.set(\"address\", address);\r",
              "pm.variables.set(\"birthdate\", pick(\"birthdate\", \"2000-01-01\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const tc = pm.iterationData.get(\"tc\");\r",
              "const desc = pm.iterationData.get(\"description\");\r",
              "const expectedStatus = Number(pm.iterationData.get(\"expected_status\"));\r",
              "\r",
              "pm.test(`${tc} - ${desc} - đúng HTTP status`, function () {\r",
              "  pm.response.to.have.status(expectedStatus);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "{{authorization}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"full_name\": \"{{full_name}}\",\r\n  \"phone\": \"{{phone}}\",\r\n  \"address\": \"{{address}}\",\r\n  \"birthdate\": \"{{birthdate}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{auth_url}}/auth/profile",
          "host": [
            "{{auth_url}}"
          ],
          "path": [
            "auth",
            "profile"
          ]
        }
      },
      "response": []
    }
  ]
}