{
  "info": {
    "_postman_id": "89451812-38a1-48d3-bc92-d867e4e49b56",
    "name": "Auth Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "50117124",
