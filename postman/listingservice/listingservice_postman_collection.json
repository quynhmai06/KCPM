{
  "info": {
    "_postman_id": "a9357e28-3ca9-4f8c-805e-83a3ebaa3753",
    "name": "Listing Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "55362457",
    "_collection_link": "https://go.postman.co/collection/55362457-a9357e28-3ca9-4f8c-805e-83a3ebaa3753?source=collection_link"
  },
  "item": [
    {
      "name": "Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const tc = pm.iterationData.get(\"tc\");\r",
              "const desc = pm.iterationData.get(\"description\");\r",
              "const expectedStatus = Number(pm.iterationData.get(\"expected_status\"));\r",
              "\r",
              "pm.test(`${tc} - ${desc} - đúng HTTP status`, function () {\r",
              "  pm.response.to.have.status(expectedStatus);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const row = pm.iterationData.toObject();\r",
              "const has = (key) => Object.prototype.hasOwnProperty.call(row, key);\r",
              "const pick = (key, fallback) => has(key) ? row[key] : fallback;\r",
              "\r",
              "function makeText(ch, len) {\r",
              "  return ch.repeat(Number(len));\r",
              "}\r",
              "\r",
              "function makeImagePath(len) {\r",
              "  const n = Number(len);\r",
              "  const ext = \".jpg\";\r",
              "  return \"a\".repeat(Math.max(1, n - ext.length)) + ext;\r",
              "}\r",
              "\r",
              "const authType = pick(\"authorization_type\", \"member\");\r",
              "\r",
              "if (authType === \"member\") {\r",
              "  pm.variables.set(\"authorization\", \"Bearer \" + pm.environment.get(\"memberToken\"));\r",
              "} else if (authType === \"blocked\") {\r",
              "  pm.variables.set(\"authorization\", \"Bearer \" + pm.environment.get(\"blockedMemberToken\"));\r",
              "} else if (authType === \"invalid\") {\r",
              "  pm.variables.set(\"authorization\", \"Bearer invalid-token\");\r",
              "} else {\r",
              "  pm.variables.set(\"authorization\", \"\");\r",
              "}\r",
              "\r",
              "const name = has(\"name_length\") ? makeText(\"n\", row.name_length) : pick(\"name\", makeText(\"n\", 90));\r",
              "const mainImage = has(\"main_image_length\") ? makeImagePath(row.main_image_length) : pick(\"main_image_url\", makeImagePath(120));\r",
              "\r",
              "pm.variables.set(\"name\", name);\r",
              "pm.variables.set(\"description\", pick(\"description_body\", \"Xe điện đã qua sử dụng\"));\r",
              "pm.variables.set(\"item_type\", pick(\"item_type\", \"vehicle\"));\r",
              "pm.variables.set(\"main_image_url\", mainImage);\r",
              "pm.variables.set(\"province\", pick(\"province\", \"Hà Nội\"));\r",
              "pm.variables.set(\"brand\", pick(\"brand\", \"VinFast\"));\r",
              "pm.variables.set(\"battery_capacity\", pick(\"battery_capacity\", \"82\"));\r",
              "\r",
              "pm.variables.set(\"price_json\", JSON.stringify(pick(\"price\", 500000000)));\r",
              "pm.variables.set(\"year_json\", JSON.stringify(pick(\"year\", 2010)));\r",
              "pm.variables.set(\"mileage_json\", JSON.stringify(pick(\"mileage\", 500000)));\r",
              "pm.variables.set(\"sub_image_urls_json\", JSON.stringify(pick(\"sub_image_urls\", [\r",
              "  \"sub1.jpg\",\r",
              "  \"sub2.jpg\",\r",
              "  \"sub3.jpg\"\r",
              "])));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "{{authorization}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{name}}\",\r\n  \"description\": \"{{description}}\",\r\n  \"price\": {{price_json}},\r\n  \"item_type\": \"{{item_type}}\",\r\n  \"main_image_url\": \"{{main_image_url}}\",\r\n  \"province\": \"{{province}}\",\r\n  \"year\": {{year_json}},\r\n  \"mileage\": {{mileage_json}},\r\n  \"sub_image_urls\": {{sub_image_urls_json}},\r\n  \"brand\": \"{{brand}}\",\r\n  \"battery_capacity\": \"{{battery_capacity}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{listing_url}}/listings/",
          "host": [
            "{{listing_url}}"
          ],
          "path": [
            "listings",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"update_listing_id\", pm.environment.get(\"update_listing_id\") || \"1\");\r",
              "pm.environment.set(\"approved_listing_id\", pm.environment.get(\"approved_listing_id\") || \"6\");\r",
              "pm.environment.set(\"missing_listing_id\", \"99999999\");\r",
              "\r",
              "const blockedToken = pm.environment.get(\"blockedMemberToken\");\r",
              "if (blockedToken) {\r",
              "  pm.environment.set(\"otherMemberToken\", blockedToken);\r",
              "}\r",
              "\r",
              "const row = pm.iterationData.toObject();\r",
              "\r",
              "const rawTargetId = String(row.target_id || \"{{update_listing_id}}\");\r",
              "const targetId = pm.variables.replaceIn(rawTargetId);\r",
              "\r",
              "pm.environment.set(\"resolved_target_id\", targetId);\r",
              "pm.variables.set(\"resolved_target_id\", targetId);\r",
              "\r",
              "console.log(`${row.tc_id} - ${row.description || \"\"}`);\r",
              "console.log(\"rawTargetId =\", rawTargetId);\r",
              "console.log(\"resolved_target_id =\", targetId);\r",
              "\r",
              "const auth = row.auth;\r",
              "\r",
              "pm.request.headers.remove(\"Authorization\");\r",
              "\r",
              "if (auth && auth !== \"none\") {\r",
              "  const token =\r",
              "    pm.environment.get(auth) ||\r",
              "    pm.collectionVariables.get(auth) ||\r",
              "    pm.globals.get(auth);\r",
              "\r",
              "  console.log(\"auth =\", auth);\r",
              "  console.log(\"token exists =\", !!token);\r",
              "  console.log(\"token preview =\", token ? token.substring(0, 30) : \"NULL\");\r",
              "\r",
              "  pm.request.headers.upsert({\r",
              "    key: \"Authorization\",\r",
              "    value: `Bearer ${token}`\r",
              "  });\r",
              "} else {\r",
              "  console.log(\"auth = none\");\r",
              "}\r",
              "\r",
              "pm.request.headers.upsert({\r",
              "  key: \"Content-Type\",\r",
              "  value: \"application/json\"\r",
              "});\r",
              "\r",
              "const payload = row.payload || {};\r",
              "console.log(\"payload =\", JSON.stringify(payload));\r",
              "\r",
              "pm.request.body.update(JSON.stringify(payload));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var tcId = pm.iterationData.get(\"tc_id\");\r",
              "var desc = pm.iterationData.get(\"description\") || \"\";\r",
              "var expected = Number(pm.iterationData.get(\"expected_status\"));\r",
              "\r",
              "var responseData = null;\r",
              "var contentType = pm.response.headers.get(\"Content-Type\") || \"\";\r",
              "var bodyText = pm.response.text();\r",
              "\r",
              "if (contentType.includes(\"application/json\") && bodyText) {\r",
              "  responseData = pm.response.json();\r",
              "}\r",
              "\r",
              "console.log(`${tcId} - ${desc}`);\r",
              "console.log(`expected status = ${expected}, actual status = ${pm.response.code}`);\r",
              "console.log(\"response body =\", bodyText);\r",
              "\r",
              "pm.test(`${tcId} - ${desc} - HTTP status ${expected}`, function () {\r",
              "  pm.response.to.have.status(expected);\r",
              "});\r",
              "\r",
              "if (expected === 200) {\r",
              "  pm.test(`${tcId} - ${desc} - cập nhật thành công có item`, function () {\r",
              "    pm.expect(responseData, bodyText).to.have.property(\"item\");\r",
              "  });\r",
              "} else {\r",
              "  pm.test(`${tcId} - ${desc} - request bị từ chối hợp lệ`, function () {\r",
              "    pm.expect(pm.response.code).to.be.at.least(400);\r",
              "  });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{listing_url}}/listings/{{resolved_target_id}}",
          "host": [
            "{{listing_url}}"
          ],
          "path": [
            "listings",
            "{{resolved_target_id}}"
          ]
        }
      },
      "response": []
    }
  ]
}