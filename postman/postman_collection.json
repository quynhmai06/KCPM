{
  "info": {
    "_postman_id": "33ff43a8-8540-47cc-b818-9f2b90b61f14",
    "name": "KCPM Backend API Automation Test",
    "description": "Collection used by GitHub Actions and Newman to verify that backend services are built, started, and reachable through HTTP/REST endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Gateway - health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{gatewayUrl}}/health",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Gateway returns HTTP 500', function () {",
              "    pm.response.to.have.status(500);",
              "});",
              "",
              "pm.test('Gateway status is ok', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
