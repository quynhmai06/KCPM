          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Auth_001 - Status 201\", () => pm.response.to.have.status(201));\r",
              "\r",
              "pm.test(\"Auth_001 - Save user id\", () => {\r",
              "  const json = pm.response.json();\r",
