  "item": [
    {
      "name": "PAYMENT_CREATE",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const label = pm.iterationData.get('tc') || 'CREATE_PAYMENT';\r",
              "const expected = Number(pm.iterationData.get('expected') || 201);\r",
              "\r",
              "pm.test(label + ' - status code is ' + expected, function () {\r",
              "    pm.response.to.have.status(expected);\r",
              "});\r",
              "\r",
              "const contentType = pm.response.headers.get(\"Content-Type\") || \"\";\r",
              "\r",
              "if (pm.response.code === 201 && contentType.includes(\"application/json\")) {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    pm.test(label + ' - response has payment fields', function () {\r",
              "        pm.expect(json).to.have.property('payment_id');\r",
              "        pm.expect(json).to.have.property('id');\r",
              "        pm.expect(json).to.have.property('order_id');\r",
              "        pm.expect(json).to.have.property('status');\r",
              "        pm.expect(json).to.have.property('amount');\r",
              "        pm.expect(json).to.have.property('checkout_url');\r",
              "    });\r",
              "\r",
              "}\r",
              "\r",
              "const gap = pm.iterationData.get('gap_note');\r",
              "if (gap) {\r",
              "    console.log(label + ' GAP NOTE: ' + gap);\r",
              "}\r",
              "if (pm.response.code === 201) {\r",
              "    const json = pm.response.json();\r",
              "    const pid = json.payment_id || json.id;\r",
              "\r",
              "    // Collection Variables\r",
              "    pm.collectionVariables.set(\"payment_id\", pid);\r",
              "    pm.collectionVariables.set(\"created_payment_id\", pid);\r",
              "\r",
              "    // Environment Variables\r",
              "    pm.environment.set(\"payment_id\", pid);\r",
              "    pm.environment.set(\"created_payment_id\", pid);\r",
              "\r",
              "    console.log(\"payment_id =\", pid);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
