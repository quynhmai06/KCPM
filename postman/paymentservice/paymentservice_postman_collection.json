    {
      "name": "PAYMENT_CONTRACT_MANAGEMENT",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// =====================================\r",
              "// PAYMENT CONTRACT MANAGEMENT\r",
              "// =====================================\r",
              "\r",
              "const row = pm.iterationData.toObject();\r",
              "\r",
              "function setRequest(payload) {\r",
              "    pm.request.headers.upsert({\r",
              "        key: \"Content-Type\",\r",
              "        value: \"application/json\"\r",
              "    });\r",
              "\r",
              "    pm.request.body.update(JSON.stringify(payload, null, 2));\r",
              "\r",
              "    console.log(\"==============\");\r",
              "    console.log(\"API :\", row.api);\r",
              "    console.log(\"URL :\", pm.environment.get(\"contract_api\"));\r",
              "    console.log(\"Payload:\");\r",
              "    console.log(JSON.stringify(payload, null, 2));\r",
              "}\r",
              "\r",
              "function createPaymentThenBuild(callback) {\r",
              "    const uniqueOrderId = \"ORD-CONTRACT-\" + row.tc_id + \"-\" + Date.now();\r",
              "\r",
              "    pm.sendRequest({\r",
              "        url: pm.environment.get(\"payment_url\") + \"/payment/create\",\r",
              "        method: \"POST\",\r",
              "        header: {\r",
              "            \"Content-Type\": \"application/json\",\r",
              "            \"Authorization\": \"Bearer \" + (pm.environment.get(\"token\") || \"\")\r",
              "        },\r",
              "        body: {\r",
              "            mode: \"raw\",\r",
              "            raw: JSON.stringify({\r",
              "                order_id: uniqueOrderId,\r",
              "                buyer_id: 1,\r",
              "                seller_id: 2,\r",
              "                amount: 50000000,\r",
              "                method: \"banking\",\r",
              "                items: []\r",
              "            })\r",
              "        }\r",
              "    }, function (err, res) {\r",
              "        if (err) {\r",
              "            console.error(\"Create payment failed:\", err);\r",
              "            setRequest({ payment_id: \"CREATE_PAYMENT_FAILED\" });\r",
              "            return;\r",
              "        }\r",
              "\r",
              "        const json = res.json();\r",
              "\r",
              "        pm.environment.set(\"contract_exists_payment_id\", json.payment_id);\r",
              "        pm.collectionVariables.set(\"contract_exists_payment_id\", json.payment_id);\r",
              "\r",
              "        callback(json.payment_id);\r",
              "    });\r",
              "}\r",
              "\r",
              "function buildCreatePayload(paymentId) {\r",
              "    let payload = {};\r",
              "\r",
              "    if (row.payment_id !== \"MISSING\") {\r",
              "        payload.payment_id = Number(paymentId);\r",
              "    }\r",
              "\r",
              "    if (row.product_info !== \"MISSING\") {\r",
              "        payload.product_info = {\r",
              "            details: row.product_details || \"\"\r",
              "        };\r",
              "    }\r",
              "\r",
              "    if (row.buyer_info !== \"MISSING\") {\r",
              "        payload.buyer_info = {\r",
              "            name: row.buyer_name || \"\",\r",
              "            email: row.buyer_email || \"\",\r",
              "            phone: row.buyer_phone || \"\"\r",
              "        };\r",
              "    }\r",
              "\r",
              "    if (row.seller_info !== \"MISSING\") {\r",
              "        payload.seller_info = {\r",
              "            name: row.seller_name || \"\",\r",
              "            email: row.seller_email || \"\",\r",
              "            phone: row.seller_phone || \"\"\r",
              "        };\r",
              "    }\r",
              "\r",
              "    if (row.cart_items && row.cart_items !== \"-\" && row.cart_items !== \"MISSING\") {\r",
              "        try {\r",
              "            payload.cart_items = JSON.parse(row.cart_items);\r",
              "        } catch (e) {\r",
              "            payload.cart_items = row.cart_items;\r",
              "        }\r",
              "    }\r",
              "\r",
              "    setRequest(payload);\r",
              "}\r",
              "\r",
              "// CREATE CONTRACT\r",
              "if (row.api === \"create\") {\r",
              "    pm.environment.set(\"contract_api\", \"/payment/contract/create-from-payment\");\r",
              "\r",
              "    if (row.payment_id === \"AUTO\") {\r",
              "        createPaymentThenBuild(function (pid) {\r",
              "            buildCreatePayload(pid);\r",
              "        });\r",
              "    }\r",
              "\r",
              "    else if (row.payment_id === \"MISSING\") {\r",
              "        buildCreatePayload(undefined);\r",
              "    }\r",
              "\r",
              "    else if (row.payment_id && row.payment_id.startsWith(\"{{\")) {\r",
              "        const existingPaymentId =\r",
              "            pm.environment.get(\"contract_exists_payment_id\") ||\r",
              "            pm.collectionVariables.get(\"contract_exists_payment_id\");\r",
              "\r",
              "        buildCreatePayload(existingPaymentId);\r",
              "    }\r",
              "\r",
              "    else {\r",
              "        buildCreatePayload(row.payment_id);\r",
              "    }\r",
              "}\r",
              "\r",
              "// SIGN CONTRACT\r",
              "else {\r",
              "    let cid = row.contract_id;\r",
              "\r",
              "    if (cid && cid.startsWith(\"{{\")) {\r",
              "        cid =\r",
              "            pm.environment.get(\"contract_id\") ||\r",
              "            pm.collectionVariables.get(\"contract_id\");\r",
              "    }\r",
              "\r",
              "    pm.environment.set(\r",
              "        \"contract_api\",\r",
              "        \"/payment/contract/sign/\" + cid\r",
              "    );\r",
              "\r",
              "    const payload = {\r",
              "        signer_role: row.signer_role,\r",
              "        signature_type: row.signature_type,\r",
              "        signature_data: row.signature_data\r",
              "    };\r",
              "\r",
              "    setRequest(payload);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const label = pm.iterationData.get(\"tc_id\") || \"PAYMENT_CONTRACT\";\r",
              "\r",
              "const expected =\r",
              "    Number(pm.iterationData.get(\"expected_status\"));\r",
              "\r",
              "pm.test(label + \" - Status code is \" + expected, function () {\r",
              "\r",
              "    pm.response.to.have.status(expected);\r",
              "\r",
              "});\r",
              "\r",
              "let json = {};\r",
              "\r",
              "try {\r",
              "\r",
              "    json = pm.response.json();\r",
              "\r",
              "}\r",
              "\r",
              "catch (e) {\r",
              "\r",
              "    json = {};\r",
              "\r",
              "}\r",
              "\r",
              "// ===============================\r",
              "// CREATE SUCCESS\r",
              "// ===============================\r",
              "\r",
              "if (\r",
              "\r",
              "    pm.iterationData.get(\"api\") === \"create\" &&\r",
              "    pm.response.code === 201\r",
              "\r",
              ") {\r",
              "\r",
              "    pm.test(\r",
              "\r",
              "        label + \" - Contract created\",\r",
              "\r",
              "        function () {\r",
              "\r",
              "            pm.expect(json)\r",
              "                .to.have.property(\"contract_id\");\r",
              "\r",
              "            pm.expect(json)\r",
              "                .to.have.property(\"contract_code\");\r",
              "\r",
              "            pm.expect(json)\r",
              "                .to.have.property(\"status\");\r",
              "\r",
              "        }\r",
              "\r",
              "    );\r",
              "\r",
              "    pm.environment.set(\r",
              "\r",
              "        \"contract_id\",\r",
              "\r",
              "        json.contract_id\r",
              "\r",
              "    );\r",
              "\r",
              "    pm.collectionVariables.set(\r",
              "\r",
              "        \"contract_id\",\r",
              "\r",
              "        json.contract_id\r",
              "\r",
              "    );\r",
              "\r",
              "}\r",
              "\r",
              "// ===============================\r",
              "// CONTRACT EXISTS\r",
              "// ===============================\r",
              "\r",
              "if (\r",
              "\r",
              "    pm.iterationData.get(\"api\") === \"create\" &&\r",
              "    pm.response.code === 200 &&\r",
              "    json.message === \"contract_exists\"\r",
              "\r",
              ") {\r",
              "\r",
              "    pm.test(\r",
              "\r",
              "        label + \" - Contract exists\",\r",
              "\r",
              "        function () {\r",
              "\r",
              "            pm.expect(json.message)\r",
              "                .to.eql(\"contract_exists\");\r",
              "\r",
              "        }\r",
              "\r",
              "    );\r",
              "\r",
              "    pm.environment.set(\r",
              "\r",
              "        \"contract_id\",\r",
              "\r",
              "        json.contract_id\r",
              "\r",
              "    );\r",
              "\r",
              "    pm.collectionVariables.set(\r",
              "\r",
              "        \"contract_id\",\r",
              "\r",
              "        json.contract_id\r",
              "\r",
              "    );\r",
              "\r",
              "}\r",
              "\r",
              "// ===============================\r",
              "// SIGN SUCCESS\r",
              "// ===============================\r",
              "\r",
              "if (\r",
              "\r",
              "    pm.iterationData.get(\"api\") === \"sign\" &&\r",
              "    pm.response.code === 200\r",
              "\r",
              ") {\r",
              "\r",
              "    pm.test(\r",
              "\r",
              "        label + \" - Contract signed\",\r",
              "\r",
              "        function () {\r",
              "\r",
              "            pm.expect(json)\r",
              "                .to.have.property(\"buyer_signed\");\r",
              "\r",
              "            pm.expect(json)\r",
              "                .to.have.property(\"seller_signed\");\r",
              "\r",
              "            pm.expect(json)\r",
              "                .to.have.property(\"contract_status\");\r",
              "\r",
              "        }\r",
              "\r",
              "    );\r",
              "\r",
              "}\r",
              "\r",
              "// ===============================\r",
              "// ERROR\r",
              "// ===============================\r",
              "\r",
              "if (\r",
              "\r",
              "    pm.response.code >= 400\r",
              "\r",
              ") {\r",
              "\r",
              "    pm.test(\r",
              "\r",
              "        label + \" - Response has error\",\r",
              "\r",
              "        function () {\r",
              "\r",
              "            pm.expect(json)\r",
              "                .to.have.property(\"error\");\r",
              "\r",
              "        }\r",
              "\r",
              "    );\r",
              "\r",
              "    const expectedError =\r",
              "        pm.iterationData.get(\"expected_error\");\r",
              "\r",
              "    if (\r",
              "\r",
              "        expectedError &&\r",
              "        expectedError !== \"-\"\r",
              "\r",
              "    ) {\r",
              "\r",
              "        pm.test(\r",
              "\r",
              "            label +\r",
              "            \" - Error contains \" +\r",
              "            expectedError,\r",
              "\r",
              "            function () {\r",
              "\r",
              "                pm.expect(\r",
              "                    JSON.stringify(json)\r",
              "                        .toLowerCase()\r",
              "                ).to.include(\r",
              "                    expectedError.toLowerCase()\r",
              "                );\r",
              "\r",
              "            }\r",
              "\r",
              "        );\r",
              "\r",
              "    }\r",
              "\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
