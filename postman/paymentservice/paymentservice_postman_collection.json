{
  "info": {
    "_postman_id": "41b689fb-065c-4b47-af29-b3737eacfa5a",
    "name": "Payment Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "55357541",
    "_collection_link": "https://go.postman.co/collection/55357541-41b689fb-065c-4b47-af29-b3737eacfa5a?source=collection_link"
  },
  "item": [
    {
      "name": "PAYMENT_CREATE",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const row = pm.iterationData.toObject();\r",
              "const has = (key) => Object.prototype.hasOwnProperty.call(row, key);\r",
              "const rawBody = pm.iterationData.get('raw_body');\r",
              "\r",
              "if (rawBody) {\r",
              "    pm.variables.set('request_body', rawBody);\r",
              "} else {\r",
              "    const payload = {};\r",
              "\r",
              "    if (has('order_id')) payload.order_id = row.order_id;\r",
              "    if (has('buyer_id')) payload.buyer_id = row.buyer_id;\r",
              "    if (has('seller_id')) payload.seller_id = row.seller_id;\r",
              "    if (has('amount')) payload.amount = row.amount;\r",
              "    if (has('method')) payload.method = row.method;\r",
              "    if (has('items')) payload.items = row.items;\r",
              "\r",
              "    pm.variables.set('request_body', JSON.stringify(payload, null, 2));\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const label = pm.iterationData.get('tc') || 'CREATE_PAYMENT';\r",
              "const expected = Number(pm.iterationData.get('expected') || 201);\r",
              "\r",
              "pm.test(label + ' - status code is ' + expected, function () {\r",
              "    pm.response.to.have.status(expected);\r",
              "});\r",
              "\r",
              "const contentType = pm.response.headers.get(\"Content-Type\") || \"\";\r",
              "\r",
              "if (pm.response.code === 201 && contentType.includes(\"application/json\")) {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    pm.test(label + ' - response has payment fields', function () {\r",
              "        pm.expect(json).to.have.property('payment_id');\r",
              "        pm.expect(json).to.have.property('id');\r",
              "        pm.expect(json).to.have.property('order_id');\r",
              "        pm.expect(json).to.have.property('status');\r",
              "        pm.expect(json).to.have.property('amount');\r",
              "        pm.expect(json).to.have.property('checkout_url');\r",
              "    });\r",
              "\r",
              "    pm.collectionVariables.set('payment_id', json.payment_id);\r",
              "}\r",
              "\r",
              "const gap = pm.iterationData.get('gap_note');\r",
              "if (gap) {\r",
              "    console.log(label + ' GAP NOTE: ' + gap);\r",
              "}\r",
              "if (pm.response.code === 201) {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    pm.collectionVariables.set(\r",
              "        \"created_payment_id\",\r",
              "        json.payment_id || json.id\r",
              "    );\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{request_body}}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{payment_url}}/payment/create",
          "host": [
            "{{payment_url}}"
          ],
          "path": [
            "payment",
            "create"
          ]
        }
      },
      "response": []
    },
    {
      "name": "PAYMENT_CONFIRM",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const paymentId = pm.iterationData.get(\"payment_id\");\r",
              "\r",
              "if (paymentId) {\r",
              "    pm.collectionVariables.set(\"payment_id\", paymentId);\r",
              "} else {\r",
              "    pm.collectionVariables.set(\r",
              "        \"payment_id\",\r",
              "        pm.collectionVariables.get(\"created_payment_id\")\r",
              "    );\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const label = pm.iterationData.get('tc') || 'PAYMENT_CONFIRM';\r",
              "\r",
              "const expected = Number(pm.iterationData.get('expected') || 200);\r",
              "\r",
              "pm.test(label + ' - status code is ' + expected, function () {\r",
              "    pm.response.to.have.status(expected);\r",
              "});\r",
              "\r",
              "const contentType = pm.response.headers.get(\"Content-Type\") || \"\";\r",
              "\r",
              "if (contentType.includes(\"application/json\")) {\r",
              "\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    if (pm.response.code === 200) {\r",
              "\r",
              "        pm.test(label + \" - response has invoice fields\", function () {\r",
              "\r",
              "            pm.expect(json).to.have.property(\"invoice_id\");\r",
              "            pm.expect(json).to.have.property(\"sale_contract_id\");\r",
              "            pm.expect(json).to.have.property(\"sign_url\");\r",
              "            pm.expect(json).to.have.property(\"payment_info\");\r",
              "\r",
              "        });\r",
              "\r",
              "        pm.collectionVariables.set(\"invoice_id\", json.invoice_id);\r",
              "        pm.collectionVariables.set(\"sale_contract_id\", json.sale_contract_id);\r",
              "        pm.collectionVariables.set(\"sign_url\", json.sign_url);\r",
              "    }\r",
              "\r",
              "    if (pm.response.code >= 400) {\r",
              "\r",
              "        pm.test(label + \" - response has error message\", function () {\r",
              "            pm.expect(json).to.be.an(\"object\");\r",
              "        });\r",
              "\r",
              "    }\r",
              "}\r",
              "\r",
              "const trace = pm.iterationData.get(\"trace\");\r",
              "\r",
              "if (trace) {\r",
              "    console.log(label + \" TRACE: \" + trace);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"full_name\": \"{{full_name}}\",\r\n    \"phone\": \"{{phone}}\",\r\n    \"method\": \"{{method}}\",\r\n    \"email\": \"{{email}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
